# ============================================================
# SmartAI-NBA — API Keys Configuration
# ============================================================
#
# HOW TO USE:
#   1. Copy this file to .streamlit/secrets.toml:
#        cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. Replace the placeholder values below with your real API keys.
#   3. Restart the app (streamlit run app.py).
#
# IMPORTANT:
#   - .streamlit/secrets.toml is in .gitignore — it will NEVER be
#     committed to version control. Your keys stay private.
#   - You can also enter keys in the ⚙️ Settings page at runtime,
#     or set them as environment variables (API_NBA_KEY,
#     ODDS_API_KEY).
#
# WHERE TO GET KEYS:
#   API-NBA (API-Sports) → https://v2.nba.api-sports.io/
#   The Odds API          → https://the-odds-api.com
# ============================================================

API_NBA_KEY  = "your_api_nba_key_here"
ODDS_API_KEY = "your_odds_api_key_here"
