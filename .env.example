# ============================================================
# Smart Pick Pro — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Used by webhook_server.py and non-Streamlit deployments.
# For Streamlit Cloud, use .streamlit/secrets.toml instead.
# ============================================================

# ── Required for DraftKings Pick6 data ────────────────────────
ODDS_API_KEY=your_the_odds_api_key

# ── Required for Stripe payments ─────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Per-tier Stripe Price IDs ────────────────────────────────
# Create these products/prices in your Stripe Dashboard.
STRIPE_PRICE_SHARP_IQ=price_...        # Sharp IQ  — $9.99/mo recurring
STRIPE_PRICE_SMART_MONEY=price_...     # Smart Money — $24.99/mo recurring
STRIPE_PRICE_INSIDER_CIRCLE=price_...  # Insider Circle — $499.99 one-time

# Legacy fallback (optional — used if per-tier IDs are not set)
STRIPE_PRICE_ID=price_...

# ── Required for production mode ─────────────────────────────
# MUST be "true" to enforce subscription gates in live deployments.
SMARTAI_PRODUCTION=true
APP_URL=https://your-app.streamlit.app

# ── Admin account (auto-created on startup) ──────────────────
# Set both to auto-seed an admin user in the DB on every boot.
ADMIN_EMAIL=admin@smartpickpro.com
ADMIN_PASSWORD=ChangeMe123

# ── RapidAPI (optional) ───────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Timeouts (seconds) ───────────────────────────────────────
NBA_API_TIMEOUT=30
ESPN_API_TIMEOUT=15
PROPS_API_TIMEOUT=15

# ── Cache Settings (hours) ───────────────────────────────────
CACHE_TTL_HOURS=1
ROSTER_CACHE_HOURS=1
PROPS_CACHE_HOURS=1

# ── Analysis Settings ────────────────────────────────────────
SIMULATION_DEPTH=2000          # Number of Quantum Matrix simulation iterations
MINIMUM_EDGE=5.0               # Minimum edge percentage required for a recommendation
MAX_PROPS_PER_PLAYER=5

# ── Feature Flags ────────────────────────────────────────────
ENABLE_PDF_PARSER=true
ENABLE_CIRCUIT_BREAKER=true
ENABLE_FUZZY_MATCHING=true

# ── Optional ─────────────────────────────────────────────────
DB_PATH=db/smartai_nba.db
LOG_LEVEL=INFO
